# Cognee Plugin for Vellum Assistant — Environment Variables
#
# Copy this file to .env and fill in the values, or export them in your shell
# before starting the Vellum Assistant daemon.
#
# All variables are optional — the plugin defaults to a local, self-managed
# Cognee server at http://127.0.0.1:8011.

# ─── Plugin → Cognee server auth ──────────────────────────────────────────────

# API key for authenticating with the Cognee server.
# For local servers: auto-minted on first run if left empty.
# For Cognee Cloud: copy your API key from the cloud dashboard.
COGNEE_API_KEY=

# Base URL of the Cognee server.
# Default: http://127.0.0.1:8011
#COGNEE_BASE_URL=http://127.0.0.1:8011

# ─── Cognee server → LLM provider (graph sync) ────────────────────────────────

# The Cognee server needs an LLM API key to run the cognify pipeline
# (session-to-graph sync). Without it, session memory (QA pairs, traces) still
# works, but permanent graph sync will fail with LLMAPIKeyNotSetError.
#
# In local mode, the plugin passes this through to the spawned server
# process automatically — just set it here or via llm_api_key_credential
# in the plugin's config.json.
COGNEE_LLM_API_KEY=

# ─── Optional plugin tuning ───────────────────────────────────────────────────

# Dataset name for storage (default: agent_sessions)
#COGNEE_PLUGIN_DATASET=agent_sessions

# Agent name for session IDs (default: vellum-assistant)
#COGNEE_AGENT_NAME=vellum-assistant

# Session ID prefix (default: vellum)
#COGNEE_SESSION_PREFIX=vellum

# Circuit breaker: failures before opening (default: 5)
#COGNEE_BREAKER_THRESHOLD=5

# Circuit breaker: cooldown in seconds (default: 120)
#COGNEE_BREAKER_COOLDOWN=120

# ─── Managed server overrides ─────────────────────────────────────────────────

# Set mode: "local" = plugin manages a local server (provisions venv + spawns
# uvicorn), "cloud" = external server. Default is local.
#COGNEE_MODE=local

# Python interpreter for venv creation (default: python3)
# Must be >= 3.10. cognee requires Python 3.10+.
#COGNEE_PYTHON=python3
